{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "components/doephone/DoePhoneDesktop*.tsx",
    "components/doephone/DoePhoneCommunicationSection.tsx",
    "components/doephone/DoePhoneCommunicationIntelligenceSection.tsx",
    "components/doephone/DoePhoneCustomizationSection.tsx",
    "components/doephone/DoePhoneIntegrationsSection.tsx",
    "components/doephone/DoePhoneClosingSection.tsx",
    "components/doephone/DoePhoneClosingFeatureStack.tsx",
    "components/doephone/DoePhoneClosingBandVisual.tsx",
    "components/doephone/DoePhoneCommIntelWorkflowCards.tsx",
    "components/doephone/DoePhoneAgentsSixGrid.tsx",
    "lib/designers/DesignersPhoneCanvas.tsx",
    "lib/join/applicant-card-email.ts",
    "lib/join/applicant-card-email-art.ts",
    "lib/join/submit-join-application.ts",
    "lib/join/use-join-*.ts",
    "lib/join/join-apply-*.ts",
    "lib/join/join-hero-backdrops.ts",
    "lib/join/join-layout.ts",
    "lib/join/join-agents-gradient.ts",
    "lib/join/canada-silhouette-path.ts",
    "lib/join/resume-file.ts",
    "lib/join/hero-agent-box-svg.tsx",
    "components/MainpageRouteLayout.tsx",
    "components/design-hero-backdrop-section.tsx",
    "components/dot-wave-canvas.tsx",
    "components/hero-carousel-texture.tsx",
    "components/hero-chart-panels.tsx",
    "components/main-page-design-backdrop.tsx",
    "components/workflow-carousel-slides.tsx"
  ]
}
